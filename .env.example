NODE_ENV=development
PORT=8080
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sv5tot
DEFAULT_SCHOOL_YEAR=2025-2026
JWT_ACCESS_SECRET=change_me
JWT_REFRESH_SECRET=change_me
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12
SEED_DEFAULT_PASSWORD=Password@123
CORS_ORIGIN=http://localhost:5173,https://sv5tot-v1.lovable.app
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20
STORAGE_DRIVER=local
VNPT_MODE=mock
VNPT_BASE_URL=
VNPT_API_KEY=
SMARTBOT_MODE=mock
LOG_LEVEL=info
STORAGE_DRIVER=r2
R2_BUCKET_NAME=5tot-evidence-dev
R2_ACCOUNT_ID=your_account_id
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
