# 5TOT backend environment example. Do not put real secrets in this file.

# Required: runtime
NODE_ENV=development
PORT=8080
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sv5tot
CORS_ORIGIN=http://localhost:5173,https://your-frontend-domain.com
DEFAULT_SCHOOL_YEAR=2025-2026
LOG_LEVEL=info

# Required: auth secrets. Use long random values outside local dev.
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=120m
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12
SEED_DEFAULT_PASSWORD=Password@123

# Optional compatibility aliases for older local scripts.
JWT_SECRET=
JWT_EXPIRES_IN=
BCRYPT_ROUNDS=

# Required for Cloud Run/stateless file storage.
STORAGE_DRIVER=r2
MAX_FILE_SIZE_MB=20
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_REGION=auto
R2_BUCKET=your-r2-bucket
R2_BUCKET_NAME=
R2_ACCOUNT_ID=<ACCOUNT_ID>
R2_PUBLIC_BASE_URL=https://your-r2-public-domain.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# Optional local-only storage. Do not use local storage for Cloud Run production uploads.
LOCAL_UPLOAD_DIR=uploads
UPLOAD_DIR=uploads

# Optional VNPT SmartReader. Mock mode does not require provider credentials.
VNPT_MODE=mock
VNPT_ENABLED=false
VNPT_REQUIRE_REAL_IN_PIPELINE=false
VNPT_ALLOW_MOCK_RUNTIME=true
VNPT_BASE_URL=https://api.idg.vnpt.vn
VNPT_API_KEY=
VNPT_ACCESS_TOKEN=
VNPT_TOKEN_ID=
VNPT_TOKEN_KEY=
VNPT_MAC_ADDRESS=EGOV-DIGDOC-WEB-API
VNPT_CLIENT_SESSION=00-14-22-01-23-45-1548211589291
VNPT_DEFAULT_TOKEN=5tot-backend
VNPT_TIMEOUT_MS=120000
VNPT_RETRY_MAX=2
VNPT_UPLOAD_PATH=/file-service/v1/addFile
VNPT_OCR_BASIC_PATH=/rpa-service/aidigdoc/v1/ocr/scan
VNPT_OCR_ADVANCED_PATH=/rpa-service/aidigdoc/v1/ocr/scan-table
VNPT_OCR_ASYNC_START_PATH=/rpa-service/aidigdoc/v1/integration/ocr/scan-table
VNPT_OCR_ASYNC_RESULT_PATH=/rpa-service/aidigdoc/v1/integration/ocr/scan-table/result
VNPT_OCR_ASYNC_CANCEL_PATH=/rpa-service/aidigdoc/v1/integration/ocr/scan-table/cancel
VNPT_ADMIN_DOC_PATH=/rpa-service/aidigdoc/v1/vlm/van-ban-hanh-chinh-vnportal
VNPT_UPLOAD_FORCE_JSON_CONTENT_TYPE=false
VNPT_SAVE_RAW_RESPONSE=false
VNPT_LOG_RAW_RESPONSE=false
SMARTREADER_SMOKE_AUDIT_ENABLED=false
SMARTREADER_ASYNC_MAX_POLLS=60

# Manual evidence analysis provider. Runtime default is OpenAI.
EVIDENCE_ANALYSIS_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_EVIDENCE_MODEL=
OPENAI_EVIDENCE_TIMEOUT_MS=30000
OPENAI_EVIDENCE_MAX_RETRIES=1
OPENAI_STORE_RESPONSES=false
OPENAI_EVIDENCE_PROMPT_VERSION=evidence-card-v1

# Optional Dashboard assistant narrative. Structured context works when disabled.
ASSISTANT_NARRATIVE_PROVIDER=disabled
OPENAI_ASSISTANT_MODEL=
OPENAI_ASSISTANT_TIMEOUT_MS=30000
OPENAI_ASSISTANT_MAX_RETRIES=1
OPENAI_ASSISTANT_PROMPT_VERSION=dashboard-assistant-v1
ASSISTANT_NARRATIVE_CACHE_TTL_MS=900000
ASSISTANT_MOCK_STREAM_DELAY_MS=35

# Optional background jobs. For Cloud Run demo, keep this false unless this service owns workers.
JOB_WORKER_ENABLED=false
JOB_WORKER_INTERVAL_MS=5000
INTERNAL_WORKER_TOKEN=

# Optional SmartBot. Mock mode does not require provider credentials.
SMARTBOT_MODE=mock
SMARTBOT_BASE_URL=https://assistant-stream.vnpt.vn
SMARTBOT_BOT_ID=
SMARTBOT_ACCESS_TOKEN=
SMARTBOT_TOKEN_ID=
SMARTBOT_TOKEN_KEY=
SMARTBOT_TIMEOUT_MS=30000
SMARTBOT_INPUT_CHANNEL=livechat
SMARTBOT_USE_DYNAMIC_PROMPT=true
SMARTBOT_WEBHOOK_TOKEN=
SMARTBOT_LOG_RAW_RESPONSE=false

# Optional Gemini.
GEMINI_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=30000
GEMINI_LOG_RAW_RESPONSE=false

# Optional mail.
MAIL_ENABLED=false
MAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM_NAME=5TOT
MAIL_FROM_ADDRESS=no-reply@example.edu.vn
APP_BASE_URL=http://localhost:5173
MAIL_MAX_ATTEMPTS=3
MAIL_RETRY_BASE_SECONDS=60

# Optional one-off scripts.
ADMIN_EMAIL=admin@dut.udn.vn
ADMIN_PASSWORD=
PERSON2_DEMO_STUDENT_CODE=102220001
PERSON2_DEMO_OTHER_STUDENT_CODE=109990001
