{
  "name": "5tot-backend",
  "version": "0.2.0",
  "description": "Backend API foundation for 5TOT Platform.",
  "main": "dist/src/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "backfill:evidence-knowledge": "tsx scripts/backfill-approved-evidence-precedents.ts",
    "backfill:requirements": "tsx scripts/backfill-requirement-responses.ts",
    "create-admin": "tsx scripts/create-admin.ts",
    "smartreader:smoke": "tsx scripts/smoke-smartreader.ts",
    "smoke:smartbot": "tsx scripts/smoke-smartbot.ts",
    "smoke:cloud-run": "tsx scripts/smoke-cloud-run-readiness.ts",
    "worker:tick": "tsx scripts/worker-tick.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1077.0",
    "@aws-sdk/s3-request-presigner": "^3.1077.0",
    "@prisma/client": "^6.10.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "openai": "^6.48.0",
    "pino": "^9.5.0",
    "pino-http": "^10.4.0",
    "read-excel-file": "^9.2.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/nodemailer": "^8.0.1",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.7",
    "eslint": "^9.17.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "prisma": "^6.10.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
