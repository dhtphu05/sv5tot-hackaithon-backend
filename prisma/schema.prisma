generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  student
  class_representative
  officer
  manager
  committee
  admin
}

enum Criterion {
  ethics
  academic
  physical
  volunteer
  integration
  priority
  collective
}

enum Level {
  school
  university
  city
  central
}

enum ApplicationType {
  individual
  collective
}

enum ApplicationStatus {
  not_started
  draft
  prechecked
  ready_to_submit
  submitted
  supplement_required
  under_review
  resolution_needed
  completed
  rejected
}

enum FinalStatus {
  pending
  passed
  failed
  partially_passed
}

enum EvidenceSourceType {
  metric_input
  event_import
  manual_upload
  collective_import
}

enum IndexingStatus {
  not_started
  uploaded
  pending_indexing
  ocr_processing
  extracting
  checking_registry
  indexed
  failed
  needs_manual_review
}

enum EvidenceStatus {
  draft
  pending_indexing
  indexed
  needs_supplement
  under_review
  accepted
  rejected
  resolution_needed
}

enum ReviewTaskStatus {
  waiting
  reviewing
  supplement_required
  accepted
  rejected
  resolution_needed
}

enum ReviewDecision {
  accepted
  rejected
  supplement_required
  resolution_needed
}

enum JobStatus {
  queued
  processing
  completed
  failed
}

enum JobType {
  evidence_ocr
  event_roster_indexing
  evidence_card_generation
  smartreader_extract
  decision_metadata
  decision_roster_ocr
}

enum SmartReaderJobType {
  evidence_ocr
  decision_metadata
  decision_roster_ocr
  criteria_doc_ocr
  smoke_test
}

enum SmartReaderJobStatus {
  queued
  uploading
  processing
  polling
  completed
  failed
  cancelled
}

enum FileStorageType {
  local
  s3
  r2
}

enum NotificationType {
  system
  deadline
  supplement_required
  supplement_requested
  precheck_completed
  review_updated
  resolution_updated
  application_updated
  export_ready
  result_available
}

enum EmailOutboxStatus {
  queued
  sending
  sent
  failed
  cancelled
}

enum ResolutionStatus {
  open
  in_review
  resolved
  rejected
}

enum KnowledgeDecision {
  accepted
  rejected
  needs_supplement
  reference_only
}

enum ApprovedEvidenceApprovalSource {
  officer
  resolution
}

enum ApprovedEvidencePrecedentStatus {
  active
  revoked
}

enum EventRegistryAliasType {
  alias
  acronym
  abbreviation
}

enum EventRegistryAliasVerificationSource {
  officer
  resolution
  registry
  manager
}

enum MetricType {
  gpa
  conduct_score
  physical_score
  volunteer_days
  foreign_language_score
}

enum VerificationStatus {
  unverified
  pending
  verified
  rejected
}

enum RequirementResponseKind {
  metric
  evidence
  official_event
  system_confirmation
}

enum RequirementResponseStatus {
  declared
  processing
  needs_verification
  verified
  rejected
  superseded
}

enum EventStatus {
  draft
  active
  archived
}

enum DecisionImportStatus {
  draft
  uploaded
  extracting_metadata
  ocr_processing
  parsing_roster
  preview_ready
  confirmed
  failed
  cancelled
}

enum DecisionTableType {
  roster
  criteria
  signature
  unknown
}

enum RosterPreviewValidationStatus {
  valid
  warning
  invalid
  duplicate
  missing_student_code
  needs_manual_review
}

enum CollectiveStatus {
  draft
  prechecked
  ready_to_submit
  submitted
  supplement_required
  under_review
  resolution_needed
  completed
  rejected
}

model Workspace {
  id                         String                           @id @default(uuid()) @db.Uuid
  code                       String                           @unique
  name                       String
  shortName                  String?
  isActive                   Boolean                          @default(true)
  registrationEnabled        Boolean                          @default(false)
  createdAt                  DateTime                         @default(now())
  updatedAt                  DateTime                         @updatedAt
  users                      User[]
  applications               Application[]
  requirementResponses       ApplicationRequirementResponse[]
  files                      File[]
  eventRegistries            EventRegistry[]
  decisionImports            DecisionImport[]
  knowledgeBaseItems         KnowledgeBaseItem[]
  criteriaVersions           CriteriaVersion[]
  reviewTasks                ReviewTask[]
  resolutionCases            ResolutionCase[]
  eventRegistryAliases       EventRegistryAlias[]
  workspaceAbbreviations     WorkspaceAbbreviation[]
  approvedEvidencePrecedents ApprovedEvidencePrecedent[]
  indexingJobs               IndexingJob[]
  smartReaderJobs            SmartReaderJob[]
  auditLogs                  AuditLog[]
  notifications              Notification[]
  collectiveProfiles         CollectiveProfile[]
  chatSessions               ChatSession[]
  chatbotActions             ChatbotAction[]
  chatbotHandoffs            ChatbotHandoff[]
  supplementRequests         SupplementRequest[]

  @@index([isActive, registrationEnabled])
}

model User {
  id                       String                           @id @default(uuid()) @db.Uuid
  workspaceId              String?                          @db.Uuid
  fullName                 String
  email                    String                           @unique
  passwordHash             String
  phone                    String?
  role                     Role                             @default(student)
  studentCode              String?
  className                String?
  faculty                  String?
  avatarUrl                String?
  isActive                 Boolean                          @default(true)
  lastLoginAt              DateTime?
  createdAt                DateTime                         @default(now())
  updatedAt                DateTime                         @updatedAt
  workspace                Workspace?                       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  refreshTokens            RefreshToken[]
  officerSpecializations   OfficerSpecialization[]
  applications             Application[]
  uploadedFiles            File[]                           @relation("UploadedFiles")
  ownedFiles               File[]                           @relation("OwnedFiles")
  createdDecisionImports   DecisionImport[]                 @relation("DecisionImportCreatedBy")
  confirmedDecisionImports DecisionImport[]                 @relation("DecisionImportConfirmedBy")
  auditLogs                AuditLog[]
  notifications            Notification[]
  requirementResponses     ApplicationRequirementResponse[]
  collectiveProfiles       CollectiveProfile[]
  assignedReviewTasks      ReviewTask[]
  finalizedApplications    Application[]                    @relation("ApplicationFinalizedBy")
  createdSupplementRequests SupplementRequest[]              @relation("SupplementRequestCreatedBy")

  @@unique([workspaceId, studentCode])
  @@index([role])
  @@index([faculty])
  @@index([isActive])
  @@index([workspaceId, role, isActive])
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model OfficerSpecialization {
  id           String    @id @default(uuid()) @db.Uuid
  officerId    String    @db.Uuid
  criterion    Criterion
  facultyScope String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  officer      User      @relation(fields: [officerId], references: [id], onDelete: Cascade)

  @@unique([officerId, criterion, facultyScope])
  @@index([criterion])
}

model Application {
  id                   String                           @id @default(uuid()) @db.Uuid
  workspaceId          String                           @db.Uuid
  studentId            String                           @db.Uuid
  schoolYear           String
  applicationType      ApplicationType
  targetLevel          Level
  status               ApplicationStatus                @default(draft)
  readinessScore       Float                            @default(0)
  currentDraftVersion  Int                              @default(1)
  submittedAt          DateTime?
  finalLevel           Level?
  finalStatus          FinalStatus                      @default(pending)
  finalNote            String?
  finalizedAt          DateTime?
  finalizedById        String?                          @db.Uuid
  createdAt            DateTime                         @default(now())
  updatedAt            DateTime                         @updatedAt
  workspace            Workspace                        @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  student              User                             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  finalizedBy          User?                            @relation("ApplicationFinalizedBy", fields: [finalizedById], references: [id], onDelete: SetNull)
  draftSnapshots       ApplicationDraftSnapshot[]
  metrics              ApplicationMetric[]
  evidences            Evidence[]
  requirementResponses ApplicationRequirementResponse[]
  precheckResults      PrecheckResult[]
  cascadeReviews       CascadeReview[]
  reviewTasks          ReviewTask[]
  resolutionCases      ResolutionCase[]
  notifications        Notification[]
  auditLogs            AuditLog[]
  supplementRequests   SupplementRequest[]

  @@unique([studentId, schoolYear, applicationType])
  @@unique([workspaceId, studentId, schoolYear, applicationType])
  @@index([workspaceId, status, targetLevel])
  @@index([workspaceId, studentId, schoolYear])
  @@index([status, targetLevel])
  @@index([targetLevel])
  @@index([studentId])
  @@index([finalStatus, finalLevel])
  @@index([finalizedById])
  @@index([studentId, schoolYear])
}

model ApplicationDraftSnapshot {
  id            String      @id @default(uuid()) @db.Uuid
  applicationId String      @db.Uuid
  version       Int
  snapshotJson  Json
  createdBy     String      @db.Uuid
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, version])
}

model ApplicationMetric {
  id                   String                           @id @default(uuid()) @db.Uuid
  applicationId        String                           @db.Uuid
  metricType           MetricType
  value                Float
  scale                Float?
  evidenceFileId       String?                          @db.Uuid
  schoolYear           String?
  source               String?
  supportingEvidenceId String?                          @db.Uuid
  verificationStatus   VerificationStatus               @default(unverified)
  createdAt            DateTime                         @default(now())
  updatedAt            DateTime                         @updatedAt
  application          Application                      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  requirementResponses ApplicationRequirementResponse[]

  @@unique([applicationId, metricType])
  @@index([verificationStatus])
}

model File {
  id                              String                      @id @default(uuid()) @db.Uuid
  workspaceId                     String?                     @db.Uuid
  ownerId                         String                      @db.Uuid
  storageType                     FileStorageType
  filePath                        String
  publicUrl                       String?
  originalName                    String
  mimeType                        String
  fileSize                        Int
  uploadedBy                      String                      @db.Uuid
  vnptHash                        String?
  vnptFileType                    String?
  vnptUploadedAt                  DateTime?
  vnptUploadRawJson               Json?
  createdAt                       DateTime                    @default(now())
  workspace                       Workspace?                  @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  owner                           User                        @relation("OwnedFiles", fields: [ownerId], references: [id], onDelete: Cascade)
  uploader                        User                        @relation("UploadedFiles", fields: [uploadedBy], references: [id], onDelete: Restrict)
  evidenceFiles                   EvidenceFile[]
  eventFiles                      EventFile[]
  decisionImports                 DecisionImport[]            @relation("DecisionImportSourceFile")
  sampleCertificateEvents         EventRegistry[]             @relation("EventSampleCertificate")
  sampleCertificateKnowledgeItems KnowledgeBaseItem[]         @relation("KnowledgeSampleCertificate")
  approvedEvidencePrecedents      ApprovedEvidencePrecedent[]

  @@index([workspaceId])
  @@index([ownerId])
  @@index([uploadedBy])
}

model Evidence {
  id                         String                           @id @default(uuid()) @db.Uuid
  applicationId              String?                          @db.Uuid
  collectiveProfileId        String?                          @db.Uuid
  evidenceName               String
  criterion                  Criterion
  sourceType                 EvidenceSourceType
  eventId                    String?                          @db.Uuid
  status                     EvidenceStatus                   @default(draft)
  indexingStatus             IndexingStatus                   @default(not_started)
  confidence                 Float?
  assignedOfficerId          String?                          @db.Uuid
  createdAt                  DateTime                         @default(now())
  updatedAt                  DateTime                         @updatedAt
  application                Application?                     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  collectiveProfile          CollectiveProfile?               @relation(fields: [collectiveProfileId], references: [id], onDelete: Cascade)
  event                      EventRegistry?                   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  evidenceFiles              EvidenceFile[]
  evidenceCard               EvidenceCard?
  approvedEvidencePrecedents ApprovedEvidencePrecedent[]
  reviewTaskEvidences        ReviewTaskEvidence[]
  requirementResponses       ApplicationRequirementResponse[]
  resolutionCases            ResolutionCase[]
  collectiveEvidences        CollectiveEvidence[]

  @@index([applicationId, criterion])
  @@index([collectiveProfileId, criterion])
  @@index([evidenceName])
  @@index([indexingStatus])
  @@index([assignedOfficerId])
}

model ApplicationRequirementResponse {
  id             String                    @id @default(uuid()) @db.Uuid
  workspaceId    String                    @db.Uuid
  applicationId  String                    @db.Uuid
  criterion      Criterion
  requirementKey String
  responseKind   RequirementResponseKind
  metricId       String?                   @db.Uuid
  evidenceId     String?                   @db.Uuid
  payloadJson    Json?
  status         RequirementResponseStatus @default(declared)
  createdBy      String                    @db.Uuid
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  workspace      Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  application    Application               @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  metric         ApplicationMetric?        @relation(fields: [metricId], references: [id], onDelete: SetNull)
  evidence       Evidence?                 @relation(fields: [evidenceId], references: [id], onDelete: SetNull)
  creator        User                      @relation(fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([workspaceId, applicationId])
  @@index([applicationId, criterion])
  @@index([applicationId, requirementKey])
  @@index([metricId])
  @@index([evidenceId])
  @@index([createdBy])
}

model EvidenceFile {
  id         String   @id @default(uuid()) @db.Uuid
  evidenceId String   @db.Uuid
  fileId     String   @db.Uuid
  fileRole   String?
  evidence   Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  file       File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([evidenceId, fileId])
}

model EvidenceCard {
  id                         String                      @id @default(uuid()) @db.Uuid
  evidenceId                 String                      @unique @db.Uuid
  ocrText                    String?
  ocrLinesJson               Json?                       @map("ocr_lines_json")
  ocrParagraphsJson          Json?                       @map("ocr_paragraphs_json")
  ocrTablesJson              Json?                       @map("ocr_tables_json")
  extractedFieldsJson        Json?
  normalizedFieldsJson       Json?                       @map("normalized_fields_json")
  warningsJson               Json?
  matchedEventId             String?                     @db.Uuid
  matchedParticipantId       String?                     @map("matched_participant_id") @db.Uuid
  matchedKnowledgeItemIds    Json?
  confidence                 Float?
  provider                   String?
  providerModel              String?                     @map("provider_model")
  promptVersion              String?                     @map("prompt_version")
  fieldConfidenceJson        Json?                       @map("field_confidence_json")
  requiresHumanConfirmation  Boolean                     @default(false) @map("requires_human_confirmation")
  confirmationStatus         String                      @default("pending") @map("confirmation_status")
  confirmedFieldsJson        Json?                       @map("confirmed_fields_json")
  confirmedByUserId          String?                     @map("confirmed_by_user_id") @db.Uuid
  confirmedAt                DateTime?                   @map("confirmed_at")
  lastCorrectedAt            DateTime?                   @map("last_corrected_at")
  sourceEndpoint             String?                     @map("source_endpoint")
  smartreaderJobId           String?                     @map("smartreader_job_id") @db.Uuid
  aiSummary                  String?
  rawAiResponse              Json?
  rawResponseJson            Json?                       @map("raw_response_json")
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  evidence                   Evidence                    @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  approvedEvidencePrecedents ApprovedEvidencePrecedent[]

  @@index([confirmationStatus])
}

model EventRegistry {
  id                         String                      @id @default(uuid()) @db.Uuid
  workspaceId                String                      @db.Uuid
  eventName                  String
  criterion                  Criterion
  organizer                  String
  organizerLevel             Level
  startDate                  DateTime?
  endDate                    DateTime?
  convertedValue             Float?
  convertedUnit              String?
  eligibleLevelsJson         Json?
  participantCount           Int                         @default(0)
  rosterIndexed              Boolean                     @default(false)
  sampleCertificateFileId    String?                     @db.Uuid
  decisionDocumentId         String?                     @db.Uuid
  sourceDecisionImportId     String?                     @db.Uuid
  officialDocumentNo         String?
  officialIssueDate          DateTime?
  officialSigner             String?
  officialIssuer             String?
  status                     EventStatus                 @default(draft)
  createdBy                  String                      @db.Uuid
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  workspace                  Workspace                   @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  sampleCertificateFile      File?                       @relation("EventSampleCertificate", fields: [sampleCertificateFileId], references: [id], onDelete: SetNull)
  decisionDocument           DecisionDocument?           @relation(fields: [decisionDocumentId], references: [id], onDelete: SetNull)
  sourceDecisionImport       DecisionImport?             @relation(fields: [sourceDecisionImportId], references: [id], onDelete: SetNull)
  evidences                  Evidence[]
  eventFiles                 EventFile[]
  participants               EventParticipant[]
  aliases                    EventRegistryAlias[]
  approvedEvidencePrecedents ApprovedEvidencePrecedent[]

  @@index([workspaceId, status])
  @@index([workspaceId, criterion])
  @@index([criterion])
  @@index([status])
  @@index([eventName])
  @@index([decisionDocumentId])
  @@index([sourceDecisionImportId])
}

model EventFile {
  id                String         @id @default(uuid()) @db.Uuid
  eventId           String         @db.Uuid
  fileId            String         @db.Uuid
  indexingStatus    IndexingStatus @default(uploaded)
  columnMappingJson Json?
  indexQualityScore Float?
  createdAt         DateTime       @default(now())
  event             EventRegistry  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  file              File           @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([eventId, fileId])
}

model EventParticipant {
  id                       String            @id @default(uuid()) @db.Uuid
  eventId                  String            @db.Uuid
  studentCode              String
  studentName              String
  className                String?
  faculty                  String?
  participationStatus      String?
  indexedRow               Int?
  convertedValue           Float?
  sourceFileId             String?           @db.Uuid
  sourceDecisionDocumentId String?           @db.Uuid
  sourcePage               Int?
  sourceTableIndex         Int?
  sourceRowIndex           Int?
  ocrConfidence            Float?
  normalizedConfidence     Float?
  rawRowJson               Json?
  event                    EventRegistry     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sourceDecisionDocument   DecisionDocument? @relation(fields: [sourceDecisionDocumentId], references: [id], onDelete: SetNull)

  @@unique([eventId, studentCode])
  @@index([studentCode])
  @@index([sourceDecisionDocumentId])
}

model DecisionImport {
  id                 String                     @id @default(uuid()) @db.Uuid
  workspaceId        String                     @db.Uuid
  title              String
  criterion          Criterion?
  eventName          String?
  organizer          String?
  organizerLevel     Level?
  startDate          DateTime?
  endDate            DateTime?
  convertedValue     Float?
  convertedUnit      String?
  eligibleLevelsJson Json?
  status             DecisionImportStatus       @default(draft)
  sourceFileId       String?                    @db.Uuid
  vnptHash           String?
  vnptFileType       String?
  metadataJobId      String?                    @db.Uuid
  rosterJobId        String?                    @db.Uuid
  createdBy          String                     @db.Uuid
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  confirmedAt        DateTime?
  confirmedBy        String?                    @db.Uuid
  lastErrorCode      String?
  lastErrorMessage   String?
  lastUserMessage    String?
  processingStep     String?
  columnMappingJson  Json?
  workspace          Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  sourceFile         File?                      @relation("DecisionImportSourceFile", fields: [sourceFileId], references: [id], onDelete: SetNull)
  creator            User                       @relation("DecisionImportCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  confirmer          User?                      @relation("DecisionImportConfirmedBy", fields: [confirmedBy], references: [id], onDelete: SetNull)
  documents          DecisionDocument[]
  tables             DecisionTable[]
  previewRows        DecisionRosterPreviewRow[]
  events             EventRegistry[]

  @@index([workspaceId, status])
  @@index([status])
  @@index([sourceFileId])
  @@index([createdBy])
  @@index([metadataJobId])
  @@index([rosterJobId])
}

model DecisionDocument {
  id                   String             @id @default(uuid()) @db.Uuid
  decisionImportId     String             @db.Uuid
  documentNo           String?
  documentType         String?
  issuer               String?
  issueDate            DateTime?
  effectiveDate        DateTime?
  signer               String?
  summary              String?
  relatedDocumentsJson Json?
  rawAdminResponseJson Json?
  createdAt            DateTime           @default(now())
  decisionImport       DecisionImport     @relation(fields: [decisionImportId], references: [id], onDelete: Cascade)
  eventRegistries      EventRegistry[]
  eventParticipants    EventParticipant[]

  @@unique([decisionImportId])
  @@index([documentNo])
}

model DecisionTable {
  id               String            @id @default(uuid()) @db.Uuid
  decisionImportId String            @db.Uuid
  pageNumber       Int?
  tableIndex       Int?
  detectedType     DecisionTableType @default(unknown)
  headerJson       Json?
  rowsCount        Int               @default(0)
  confidence       Float?
  rawTableJson     Json
  createdAt        DateTime          @default(now())
  decisionImport   DecisionImport    @relation(fields: [decisionImportId], references: [id], onDelete: Cascade)

  @@index([decisionImportId])
  @@index([detectedType])
}

model DecisionRosterPreviewRow {
  id                     String                        @id @default(uuid()) @db.Uuid
  decisionImportId       String                        @db.Uuid
  studentCode            String?
  studentName            String?
  className              String?
  faculty                String?
  criterion              Criterion?
  convertedValue         Float?
  convertedUnit          String?
  participationStatus    String?
  sourcePage             Int?
  sourceTableIndex       Int?
  sourceRowIndex         Int?
  validationStatus       RosterPreviewValidationStatus
  validationWarningsJson Json?
  rawRowJson             Json?
  createdAt              DateTime                      @default(now())
  decisionImport         DecisionImport                @relation(fields: [decisionImportId], references: [id], onDelete: Cascade)

  @@index([decisionImportId])
  @@index([studentCode])
  @@index([validationStatus])
}

model KnowledgeBaseItem {
  id                      String            @id @default(uuid()) @db.Uuid
  workspaceId             String            @db.Uuid
  evidenceName            String?
  eventName               String?
  criterion               Criterion
  level                   Level?
  decision                KnowledgeDecision
  reason                  String?
  sampleCertificateFileId String?           @db.Uuid
  requiredFieldsJson      Json?
  commonErrorsJson        Json?
  usageCount              Int               @default(0)
  createdBy               String            @db.Uuid
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  workspace               Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  sampleCertificateFile   File?             @relation("KnowledgeSampleCertificate", fields: [sampleCertificateFileId], references: [id], onDelete: SetNull)

  @@index([workspaceId, criterion, level])
  @@index([criterion, level])
  @@index([evidenceName])
  @@index([eventName])
}

model EventRegistryAlias {
  id                 String                               @id @default(uuid()) @db.Uuid
  workspaceId        String                               @db.Uuid
  eventId            String                               @db.Uuid
  criterion          Criterion
  alias              String
  normalizedAliasKey String
  aliasType          EventRegistryAliasType               @default(alias)
  verificationSource EventRegistryAliasVerificationSource @default(officer)
  createdBy          String?                              @db.Uuid
  createdAt          DateTime                             @default(now())
  updatedAt          DateTime                             @updatedAt
  workspace          Workspace                            @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  event              EventRegistry                        @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, eventId, normalizedAliasKey])
  @@index([workspaceId, criterion, normalizedAliasKey])
  @@index([workspaceId, normalizedAliasKey])
  @@index([eventId])
}

model WorkspaceAbbreviation {
  id                    String    @id @default(uuid()) @db.Uuid
  workspaceId           String    @db.Uuid
  token                 String
  normalizedTokenKey    String
  expandedText          String
  normalizedExpandedKey String
  isActive              Boolean   @default(true)
  createdBy             String?   @db.Uuid
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)

  @@unique([workspaceId, normalizedTokenKey])
  @@index([workspaceId, isActive])
}

model ApprovedEvidencePrecedent {
  id                     String                          @id @default(uuid()) @db.Uuid
  workspaceId            String                          @db.Uuid
  criterion              Criterion
  eventId                String                          @db.Uuid
  sourceEvidenceId       String                          @db.Uuid
  sourceEvidenceCardId   String?                         @db.Uuid
  sourceReviewTaskId     String?                         @db.Uuid
  sourceResolutionCaseId String?                         @db.Uuid
  previewFileId          String?                         @db.Uuid
  approvalSource         ApprovedEvidenceApprovalSource
  organizer              String?
